{
  "schemaVersion": 1,
  "packId": "diapason-core",
  "packVersion": "1.0.0",
  "configurationKey": "diapason",
  "description": "Pack d'interface et de sons pour la configuration de démonstration Diapason.",
  "basePath": "assets/diapason",
  "naming": "{kind}/{nom-amont}.{format}",
  "palette": {
    "ink": "#17344a",
    "ivory": "#fffaf0",
    "sage": "#7a9a55",
    "gold": "#d7a746",
    "azure": "#2f7fa0"
  },
  "recoloring": "Les visuels sont livrés en gris neutre amont. La teinte Diapason est appliquée côté client (CSS currentColor, filtre ou fill), jamais en modifiant les fichiers sources.",
  "gaps": [
    {
      "kind": "ambience",
      "status": "absent",
      "reason": "Le catalogue audio de Kenney ne contient que des sons courts et des jingles ; aucune boucle d'ambiance ni musique longue n'y existe. Aucune source non CC0 n'a été substituée."
    },
    {
      "kind": "illustrations",
      "status": "absent",
      "reason": "Kenney ne publie pas d'illustrations 2D peintes compatibles avec la direction artistique Diapason. Aucune source non CC0 n'a été substituée."
    },
    {
      "kind": "music",
      "status": "partiel",
      "reason": "Seules des signatures courtes (stingers) sont disponibles ; les pistes musicales de 48 s par acte restent à produire."
    }
  ],
